# foxglove_msgs/msg/JointState
# State of a set of joints. Each joint is uniquely identified by its name. All non-empty arrays should have the same length.

# Generated by https://github.com/foxglove/foxglove-sdk

# Timestamp of the joint state data
builtin_interfaces/Time timestamp

# Joint names
string[] name

# Joint positions in radians (revolute) or meters (prismatic)
float64[] position

# Joint velocities in rad/s (revolute) or m/s (prismatic)
float64[] velocity

# Joint efforts in Nm (revolute) or N (prismatic)
float64[] effort
